{
  "$schema": "https://schema.tauri.app/config-2.json",
  "build": {
    "beforeBuildCommand": "npm run ui:build",
    "beforeDevCommand": "npm run ui:dev",
    "devPath": "http://localhost:5000",
    "distDir": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "productName": "NEURA Desktop",
  "version": "1.0.0",
  "identifier": "com.neura.desktop",
  "app": {
    "windows": [
      {
        "title": "NEURA",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ]
  },
  "security": {
    "csp": "default-src 'self'; media-src blob: 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'",
    "permissions": [
      "core:default",
      "event:default"
    ]
  }
}
